{
  "name": "socio-social-operations",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "npm run test && npm run typecheck && next build",
    "start": "next start",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs && node --env-file=.env.local scripts/migrate-imports.mjs",
    "test": "node scripts/run-tests.mjs",
    "check": "npm run format:check && npm run build && npm run test:routes",
    "test:routes": "node tests/routes.mjs",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check . --ignore-path .gitignore"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "adm-zip": "^0.6.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "workflow": "^4.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
