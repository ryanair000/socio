{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socio.jengasites.com/schemas/content-pack-1.0.json",
  "title": "Socio content pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "brand", "timezone", "campaign", "posts"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "brand": { "enum": ["chezahub", "jengasites"] },
    "timezone": { "const": "Africa/Nairobi" },
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "sourceWeek": { "type": "string", "maxLength": 64 }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platforms": { "$ref": "#/$defs/platforms" },
        "overduePolicy": { "enum": ["keep_draft", "roll_forward", "skip_expired", "stagger_from_now"] }
      }
    },
    "posts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 70,
      "items": { "$ref": "#/$defs/post" }
    }
  },
  "$defs": {
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["facebook", "instagram", "tiktok"] }
    },
    "post": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "title", "caption", "media"],
      "properties": {
        "reference": { "type": "string", "minLength": 1, "maxLength": 120 },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "caption": { "type": "string", "maxLength": 2200 },
        "format": { "enum": ["single", "carousel"] },
        "media": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "platforms": { "$ref": "#/$defs/platforms" },
        "schedule": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["date", "time"],
              "properties": {
                "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" }
              }
            }
          ]
        },
        "qaStatus": { "enum": ["ready", "ready_after_qa", "hold"] },
        "holdReason": { "type": "string", "maxLength": 500 },
        "detectedText": { "type": "string", "maxLength": 5000 },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "maxLength": 120 },
              "catalogueReference": { "type": "string", "maxLength": 160 },
              "displayedPrice": { "type": "number", "minimum": 0 },
              "cataloguePrice": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
